# RAG QA Agent Configuration

# Paths
DOCS_DIR=docs
DB_DIR=db
AUDIT_DIR=audit

# Models
CHAT_MODEL=qwen2.5:1.5b-instruct  # Recommended model for 8GB RAM
EMBED_MODEL=nomic-embed-text      # Recommended local embedding model

# RAG Settings
RETRIEVAL_K=3
CHUNK_SIZE=500
CHUNK_OVERLAP=50
CONFIDENCE_THRESHOLD=0.7

# Security & Audit
AUDIT_DB_KEY=                     # Key to encrypt SQLite DB (SQLCipher)
