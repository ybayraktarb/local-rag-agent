# RAG QA Agent Configuration

# Paths
DOCS_DIR=docs
DB_DIR=db
AUDIT_DIR=audit
OLLAMA_BASE_URL=http://localhost:11434

# Models
CHAT_MODEL=qwen2.5:1.5b-instruct  # Recommended model for 8GB RAM
EMBED_MODEL=bge-m3

# RAG Settings
RETRIEVAL_K=3
CHUNK_SIZE=500
CHUNK_OVERLAP=50
CONFIDENCE_THRESHOLD=0.45
CONFIDENCE_HIGH_THRESHOLD=0.80

# Security & Audit
AUDIT_ENABLED=false
AUDIT_DB_KEY=
